{
  "productName": "iSpeak",
  "version": "0.1.0",
  "identifier": "tech.cloudsine.ispeak",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "iSpeak",
        "width": 620,
        "height": 540,
        "minWidth": 520,
        "minHeight": 460,
        "resizable": true,
        "decorations": true,
        "visible": true,
        "center": true
      },
      {
        "label": "indicator",
        "title": "",
        "width": 48,
        "height": 48,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "resizable": false,
        "x": 40,
        "y": 40
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.plist",
      "infoPlist": "Info.plist"
    }
  }
}
